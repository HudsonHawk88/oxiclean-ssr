{
  "name": "oxiclean-ssr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server && npm run build:node",
    "build:client": "vite build",
    "build:server": "vite build --ssr",
    "build:node": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external",
    "lint": "eslint .",
    "preview": "NODE_ENV=production node dist/server.js",
    "preview-win": "set NODE_ENV=production&&node dist/server.js",
    "prod": "npx pm2 start server/server.config.cjs --env production",
    "stop-prod": "npx pm2 stop oxiclean && npx pm2 delete oxiclean"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "express": "^5.1.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mysql2": "^3.15.3",
    "nodemailer": "8.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-google-recaptcha": "^3.1.0",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-router": "^7.8.2",
    "react-toastify": "^11.0.5",
    "reactstrap": "^9.2.3",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-google-recaptcha": "^2.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "7.3.2"
  }
}
